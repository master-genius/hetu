{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SuperSSH",
  "version": "0.1.0",
  "identifier": "dev.superssh.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "SuperSSH",
        "width": 1280,
        "height": 820,
        "minWidth": 640,
        "minHeight": 400,
        "transparent": true,
        "decorations": false,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png"]
  }
}
